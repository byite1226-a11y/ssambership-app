# ⚠️ 개발(로컬 Supabase) 전용. 출시 시 원격 production URL/anon key로 교체. (README 참조)
#
# Supabase URL 은 플랫폼별로 분기된다(core/config/app_config.dart). 아래는 '기본/데스크탑' 값.
#   - Android 에뮬레이터 : http://10.0.2.2:54321  (호스트 127.0.0.1 매핑)
#   - iOS 시뮬레이터/데스크탑 : http://127.0.0.1:54321
#   - 실기기 : PC의 LAN IP (예: http://192.168.x.x:54321) → SUPABASE_URL_LAN 에 채울 것(README)
SUPABASE_URL=http://127.0.0.1:54321

# 실기기용 LAN URL (값 비움 — README 안내대로 PC IP 입력)
SUPABASE_URL_LAN=

# 로컬 Supabase anon key (공개 데모 키 — 비밀 아님). 출시 시 원격 anon key로 교체.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
